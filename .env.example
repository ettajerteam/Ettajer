# Database — pooler for runtime (Vercel/serverless); direct for `prisma db push`
DATABASE_URL="postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?pgbouncer=true"
DIRECT_URL="postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-in-production"

# Public app origin (available on server + client). Keep in sync with NEXTAUTH_URL for local.
# Used for absolute store links in the dashboard to avoid hydration mismatches.
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Resend (https://resend.com) — domain ettajer.com verified
RESEND_API_KEY="re_xxxxxxxxx"

# Sender for transactional mail (login links, password reset, order emails)
EMAIL_FROM="Ettajer <noreply@ettajer.com>"

# Inbox for contact form submissions
SUPPORT_EMAIL="support@ettajer.com"

# Platform admin emails (comma-separated). Default owner: ettajerteam@gmail.com
ADMIN_EMAILS="ettajerteam@gmail.com"

# Google Cloud ops (service account — secrets/ettajer-ops.json)
GCP_PROJECT_ID="ettajer-501512"
GOOGLE_APPLICATION_CREDENTIALS="./secrets/ettajer-ops.json"
ETTAJER_OPS_SA="ettajer-ops@ettajer-501512.iam.gserviceaccount.com"
NEXT_PUBLIC_GA_MEASUREMENT_ID="G-XXXXXXXX"
# Google Tag Manager container (platform site). Default: GTM-WZ7QXGGP
NEXT_PUBLIC_GTM_ID="GTM-WZ7QXGGP"
# GA4_PROPERTY_ID="123456789"
SEARCH_CONSOLE_SITE_URL="sc-domain:ettajer.com"
# Public launch datetime (ISO). Default: 2026-07-23 Casablanca midnight.
ETTAJER_LAUNCH_TARGET="2026-07-23T00:00:00.000+01:00"
# Platform readiness (90–94). Floor is 90 so early-access always shows Beta testing now.
NEXT_PUBLIC_ETTAJER_LAUNCH_PROGRESS="90"
ETTAJER_LAUNCH_PROGRESS="90"

# Uploadthing (https://uploadthing.com) — for product image uploads
UPLOADTHING_TOKEN=""
UPLOADTHING_APP_ID=""

# Public site URL for SEO (sitemap, Open Graph, canonical URLs)
# Production: https://ettajer.com
# Local: can stay as production — getSiteUrl() uses NEXT_PUBLIC_APP_URL / localhost in development
NEXT_PUBLIC_SITE_URL="https://ettajer.com"

# Custom domain DNS targets shown to merchants (Vercel defaults)
# NEXT_PUBLIC_DOMAIN_CNAME_TARGET="cname.vercel-dns.com"
# NEXT_PUBLIC_DOMAIN_A_TARGET="76.76.21.21"

# Vercel Domains API — required for merchant custom domains (SSL + routing)
# Create a token: https://vercel.com/account/tokens
# Project ID: Vercel → Project → Settings → General
# Team ID: Vercel → Team Settings → General (if using a team)
# VERCEL_TOKEN=""
# VERCEL_PROJECT_ID=""
# VERCEL_TEAM_ID=""
