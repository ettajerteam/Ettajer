# Database
DATABASE_URL="postgresql://user:password@localhost:5432/ettajer?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your-secret-key-change-in-production"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""

# Resend (https://resend.com) — domain ettajer.com verified
RESEND_API_KEY="re_xxxxxxxxx"

# Sender for transactional mail (login links, password reset, order emails)
EMAIL_FROM="Ettajer <noreply@ettajer.com>"

# Inbox for contact form submissions
SUPPORT_EMAIL="support@ettajer.com"

# Uploadthing (https://uploadthing.com) — for product image uploads
UPLOADTHING_TOKEN=""
UPLOADTHING_APP_ID=""

# Public site URL for SEO (sitemap, Open Graph, canonical URLs)
# Production: https://ettajer.com
# Local dev: leave as production URL; getSiteUrl() uses NEXTAUTH_URL in development
NEXT_PUBLIC_SITE_URL="https://ettajer.com"
